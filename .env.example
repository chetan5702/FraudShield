# FraudShield — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM API Key ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here

# ── Optional: override data paths ─────────────────────────────────────────────
# IEEE_CIS_PATH=C:/path/to/ieee_cis.csv
# PAYSIM_PATH=C:/path/to/paysim.csv
# REAL_DATA_PATH=C:/path/to/DataSet.csv

# ── Optional: override thresholds ─────────────────────────────────────────────
# RISK_THRESHOLD=0.40
# MULE_THRESHOLD_SUSPECT=0.40
# MULE_THRESHOLD_HIGH_RISK=0.65

# ── Optional: override ML settings ────────────────────────────────────────────
# ISO_CONTAMINATION=0.04
# XGB_N_ESTIMATORS=300
